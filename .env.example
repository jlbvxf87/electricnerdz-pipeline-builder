# Pipeline Builder — environment. Copy to .env.local (never commit real keys).

# --- The brain: Claude writes each email (the Head) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=            # optional; defaults to a current Claude model

# --- Finding leads ---
GOOGLE_PLACES_API_KEY=      # console.cloud.google.com -> enable "Places API (New)"
HUNTER_API_KEY=            # optional backup for email finding

# --- Data (Supabase / Postgres) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Sending: cold outreach from your real mailbox (Zoho SMTP) ---
ZOHO_SMTP_USER=you@yourdomain.com
ZOHO_SMTP_PASS=            # Zoho App Password (not your login password)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465

# --- Owner alerts + warm/transactional mail (Resend) ---
RESEND_API_KEY=
RESEND_FROM=Electric Nerdz <hello@yourdomain.com>
LEAD_NOTIFY_TO=you@yourdomain.com

# --- Outreach settings ---
OUTREACH_FROM=you@yourdomain.com
OUTREACH_OWNER=you@yourdomain.com
OUTREACH_POSTAL_ADDRESS=Your Business, 123 Main St, City, ST 00000   # REQUIRED by CAN-SPAM
OUTREACH_NICHE=HVAC contractors
OUTREACH_CITY=Kansas City
LEADS_PER_RUN=25
OUTREACH_DAILY_CAP=15

# --- Scheduling / security ---
CRON_SECRET=               # a long random string; also used for manual ?secret= runs
PUBLIC_BASE_URL=https://your-app.vercel.app

# --- Approve from your phone (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
