# Agent Lab environment (copy to .env.local, never commit real keys)

# --- Decide/Draft step (Claude) ---
ANTHROPIC_API_KEY=
# optional override; defaults to a current Claude model
ANTHROPIC_MODEL=

# --- Warm / transactional agents -> Resend (you already use this) ---
RESEND_API_KEY=
RESEND_FROM=Electric Nerdz <hello@electricnerdz.biz>

# --- Cold outreach (Pipeline Builder) -> Zoho mailbox over SMTP ---
# Zoho: smtp.zoho.com, port 465 (SSL). Use an app-specific password if 2FA is on,
# and make sure IMAP/SMTP access is enabled in Zoho Mail settings.
ZOHO_SMTP_USER=jaron@electricnerdz.biz
ZOHO_SMTP_PASS=
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
